{
  "version": 2,
  "builds": [
    {
      "src": "kotopy/wsgi.py",
      "use": "@vercel/python",
      "config": { "runtime": "python3.12" }
    },
    {
      "src": "staticfiles/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "kotopy/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "kotopy.settings"
  }
}