{
  "version": 2,
  "builds": [
    {
      "src": "kotopy/wsgi.py",
      "use": "@vercel/python",
      "config": { "runtime": "python3.12" }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "kotopy/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "kotopy.settings"
  },
  "buildCommand": "python manage.py collectstatic --noinput"
}